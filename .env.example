# Non-secret local Compose settings only.
MAILGATE_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
MAILGATE_DATABASE_NAME=mailgate
MAILGATE_DATABASE_USER=mailgate
MAILGATE_ENVIRONMENT=development
MAILGATE_HTTP_PORT=8080

# Secrets are files under .local/secrets by default. To store them elsewhere,
# set MAILGATE_SECRETS_DIR to that directory; do not put secret values here.
# MAILGATE_SECRETS_DIR=/absolute/path/to/mailgate-secrets
